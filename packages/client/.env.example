# Copy to `.env.development`, `.env.production`, or `.env.local` (see Vite docs).
# Only `VITE_`-prefixed keys are exposed on `import.meta.env`.

# Colyseus base URL: scheme + host + port (same origin your server listens on over HTTP).
# For local dev, keep this in sync with `PORT` in packages/server `.env.development`.
VITE_COLYSEUS_URL=http://localhost:4527

# Production: set in `.env.production` or inject in CI before `vite build`:
# VITE_COLYSEUS_URL=https://api.example.com
