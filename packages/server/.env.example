# Copy to `.env.development` or `.env.production` in this directory.
# Loaded by `src/load-env.ts` based on NODE_ENV (see package.json scripts).

# Optional marker for debugging which file was loaded
SAMPLE=development

# HTTP listen port. For local dev, align with client `VITE_COLYSEUS_URL`.
PORT=4527

# --- Typical `.env.production` overrides ---
# SAMPLE=production
# PORT=8080
# On PaaS, omit PORT here if the platform injects it (dotenv will not override).
