{
  "private": true,
  "name": "@whospy/server",
  "version": "1.0.0",
  "description": "Who's Spy? - Colyseus server",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production tsx watch src/index.ts",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**/*.test.ts --exit --timeout 15000"
  },
  "author": "LinericTW",
  "license": "UNLICENSED",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "mocha": "^11.7.5",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.0",
    "@colyseus/tools": "^0.17.0",
    "@whospy/shared": "*",
    "colyseus": "^0.17.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  }
}
