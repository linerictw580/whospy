{
  "private": true,
  "name": "whospy",
  "version": "1.0.0",
  "description": "Who's Spy? - A Multiplayer Version of the Classic Game",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run dev -w @whospy/server\" \"npm run dev -w @whospy/client\"",
    "dev:server": "npm run dev -w @whospy/server",
    "dev:client": "npm run dev -w @whospy/client",
    "start": "npm run start -w @whospy/server",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @whospy/server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "author": "LinericTW",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.59.2"
  }
}
