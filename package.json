{
  "private": true,
  "name": "whospy",
  "version": "1.0.0",
  "description": "Who's Spy? - A Multiplayer Version of the Classic Game",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "author": "LinericTW",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.0",
    "@colyseus/tools": "^0.17.0",
    "colyseus": "^0.17.6",
    "express": "^4.18.2"
  }
}
